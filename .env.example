# ─── DeskBot Configuration ───

# Ollama LLM settings
OLLAMA_HOST=http://localhost:11434 # Or your server address if not running locally
OLLAMA_MODEL=llama3.1:8b

# Display settings
DISPLAY_WIDTH=1080
DISPLAY_HEIGHT=1080
FULLSCREEN=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG